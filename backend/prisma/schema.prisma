datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      String   @default("Admin")
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id        String   @id @default(uuid())
  customer  String
  location  String
  plan      String
  cost      Float
  date      String   // Using string like "15th" or integer
  cardId    String?
  card      PaymentMethod? @relation(fields: [cardId], references: [id])
  status    String   @default("Active") // Active, Suspended
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  payments  PaymentHistory[]
}

model PaymentMethod {
  id        String   @id @default(uuid())
  name      String
  type      String   // Visa, Mastercard
  last4     String
  balance   Float
  currency  String   @default("USD")
  color     String   @default("linear-gradient(135deg, #4318FF 0%, #868CFF 100%)")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
  payments      PaymentHistory[]
}

model PaymentHistory {
  id             String   @id @default(uuid())
  date           DateTime @default(now())
  amount         Float
  status         String   // Success, Failed
  receipt        String?
  
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  
  methodId       String?
  method         PaymentMethod? @relation(fields: [methodId], references: [id])
}
